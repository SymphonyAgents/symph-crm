{
  "name": "symph-crm",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel -r run dev",
    "dev:web": "pnpm --filter @symph-crm/web dev",
    "dev:api": "pnpm --filter @symph-crm/api dev",
    "build": "pnpm -r run build",
    "build:web": "pnpm --filter @symph-crm/web build",
    "build:api": "pnpm --filter @symph-crm/api build",
    "lint": "pnpm -r run lint",
    "db:generate": "pnpm --filter @symph-crm/database generate",
    "db:migrate": "pnpm --filter @symph-crm/database migrate",
    "db:studio": "pnpm --filter @symph-crm/database studio"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "@babel/plugin-transform-modules-systemjs": "^7.29.4",
      "@xmldom/xmldom": "^0.9.10",
      "fast-uri": "^3.1.2",
      "lodash": "^4.18.1",
      "path-to-regexp": "^8.4.2",
      "picomatch": "^4.0.4",
      "protobufjs": "^7.5.6",
      "serialize-javascript": "^7.0.5",
      "shell-quote": "^1.8.4",
      "ws": "^8.21.0",
      "form-data": "^4.0.6",
      "multer": "^2.2.0"
    }
  }
}
