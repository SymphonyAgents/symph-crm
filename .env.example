DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

NEXT_PUBLIC_APP_URL=http://localhost:3000

NEXTAUTH_SECRET=your_nextauth_secret
NEXTAUTH_URL=http://localhost:3000

# Google OAuth — used for user login (NextAuth) AND Google Calendar API
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Redirect URI for Calendar OAuth callback (must be added in Google Cloud Console)
GOOGLE_CALENDAR_REDIRECT_URI=https://symph-crm-api-t5wb3mrt7q-as.a.run.app/api/auth/google-calendar/callback

# Internal endpoints (Cloud Scheduler sweep + calendar-sync)
# Generate: openssl rand -hex 32  → store in Secret Manager as symph-crm-internal-secret
INTERNAL_SECRET=your_internal_secret

# AES-256-GCM key for encrypting Google Calendar refresh tokens at rest
# Generate: openssl rand -base64 32  → store in Secret Manager as symph-crm-calendar-encryption-key
CALENDAR_ENCRYPTION_KEY=your_calendar_encryption_key

# Web app URL (for OAuth redirects after calendar connect)
WEB_BASE_URL=https://crm.symph.co

CRON_SECRET=your_cron_secret

ANTHROPIC_API_KEY=your_anthropic_api_key
